# DataPilot Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# LLM Provider API Keys (FREE tiers available)
# ============================================

# Groq - FREE tier: https://console.groq.com (primary LLM)
GROQ_API_KEY=gsk_your_key_here

# Google Gemini - FREE tier: https://aistudio.google.com (fallback LLM)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: OpenAI-compatible endpoint (for local Ollama, etc.)
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# ============================================
# Application Settings
# ============================================
DATAPILOT_ENV=development
DATAPILOT_LOG_LEVEL=INFO
DATAPILOT_HOST=0.0.0.0
DATAPILOT_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/sample_db/business.db

# ChromaDB (vector store)
CHROMA_PERSIST_DIR=./data/chroma_db

# ============================================
# Agent Settings
# ============================================
SQL_AGENT_CONFIDENCE_THRESHOLD=0.7
DOCUMENT_AGENT_CHUNK_SIZE=512
DOCUMENT_AGENT_CHUNK_OVERLAP=50
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# ============================================
# MCP Server Settings
# ============================================
MCP_SQL_PORT=8010
MCP_DOCUMENT_PORT=8011
MCP_ANALYTICS_PORT=8012
